{
	"name": "pawelknorps.github.io",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "node scripts/generateSitemap.mjs && vite build",
		"preview": "vite preview",
		"deploy": "gh-pages -d build -t",
		"pipeline:validate": "node scripts/validatePortfolio.mjs",
		"pipeline:schema-drift": "node scripts/checkSchemaDrift.mjs",
		"pipeline:bundle-budget": "BUNDLE_BUDGET_JS_BYTES=760000 node scripts/checkBundleBudget.mjs",
		"pipeline:visual-contract": "node scripts/checkVisualContract.mjs",
		"pipeline:sitemap": "node scripts/generateSitemap.mjs",
		"pipeline:ci": "npm run pipeline:validate && npm run pipeline:schema-drift && npm run build && npm run pipeline:bundle-budget && npm run pipeline:visual-contract"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.2.1",
		"autoprefixer": "^10.4.19",
		"postcss": "^8.4.38",
		"svelte": "^5.0.0",
		"svelte-intersection-observer": "^1.0.0",
		"tailwindcss": "^4.2.1",
		"vite": "^7.3.1"
	},
	"type": "module",
	"dependencies": {
		"@rnbo/js": "^1.4.2",
		"@sanity/client": "^7.16.0",
		"gh-pages": "^4.0.0",
		"simplenoise": "^1.0.1",
		"three": "^0.183.1",
		"web-vitals": "^5.1.0"
	}
}
